# ==========================
# AuditGraph - Backend Config
# ==========================
# Copy this file to the appropriate env file for your tier:
#   .env.local  — local development (Docker Postgres, no Azure)
#   .env.dev    — Azure dev  (eus2-ag-nonprod-pg / auditgraph_dev_eastus2)
#   .env.qa     — Azure QA   (eus2-ag-nonprod-pg / auditgraph_qa_eastus2)
#   .env.stg    — Azure stg  (eus2-ag-nonprod-pg / auditgraph_stg_eastus2)
#   (prod uses container runtime env vars — no .env file)

# --------------------------
# Environment Tier
# --------------------------
APP_ENV=local

# --------------------------
# Database (DATABASE_URL is primary; individual DB_* vars override)
# --------------------------
# Option A: Local Docker Postgres (recommended for local dev)
DATABASE_URL=postgresql://auditgraph:auditgraph@localhost:5434/auditgraph
DB_ADMIN_USER=auditgraph
DB_ADMIN_PASSWORD=auditgraph
DB_SSLMODE=disable

# Option B: Azure PostgreSQL Flexible Server
# NOTE: Password must be URL-encoded (%40 for @, %21 for !)
# DATABASE_URL=postgresql://auditgraph_app:PASSWORD@eus2-ag-nonprod-pg.postgres.database.azure.com:5432/auditgraph_dev_eastus2?sslmode=require&connect_timeout=10
# DB_ADMIN_USER=auditgraph_admin
# DB_ADMIN_PASSWORD=REPLACE_ME
# DB_SSLMODE=require

# Note: Individual DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD vars
# override the corresponding component parsed from DATABASE_URL.
# DB_ADMIN_USER and DB_ADMIN_PASSWORD are always separate (dual-user RLS).

# --------------------------
# Azure Discovery (Service Principal / Read-only)
# --------------------------
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=REPLACE_ME
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --------------------------
# JWT Authentication
# --------------------------
JWT_SECRET=REPLACE_ME
ADMIN_JWT_SECRET=REPLACE_ME
CLIENT_JWT_SECRET=REPLACE_ME

# --------------------------
# Email Notifications (SMTP)
# --------------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=REPLACE_ME
SMTP_FROM_EMAIL=your-email@example.com
SMTP_TO_EMAIL=recipient@example.com
SMTP_USE_TLS=true

# --------------------------
# Scheduler Configuration
# --------------------------
DISCOVERY_INTERVAL_HOURS=12
