# ==========================
# AuditGraph - Backend Config
# ==========================

# --------------------------
# Azure Discovery (Service Principal / Read-only)
# --------------------------
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=REPLACE_ME
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --------------------------
# Database (choose ONE mode)
# --------------------------

# Option A: Azure PostgreSQL Flexible Server (recommended for shared DEV)
DB_HOST=auditgraph-db-dev.postgres.database.azure.com
DB_PORT=5432
DB_NAME=auditgraph
DB_USER=auditgraph_admin
DB_PASSWORD=REPLACE_ME
DB_SSLMODE=require

# Option B: Local Docker Postgres (recommended for local/offline dev + CI)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=auditgraph
# DB_USER=auditgraph
# DB_PASSWORD=auditgraph
# DB_SSLMODE=disable
