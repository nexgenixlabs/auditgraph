#!/usr/bin/env python3
"""
Add debug logging to see what fields service principals actually have
"""

with open('azure_discovery.py', 'r') as f:
    content = f.read()

# Add debug logging after we fetch service principals
old_code = '''                for sp in sps.value:
                    if len(identities) < 10:
                        print(f"    ✓ {sp.display_name} ({sp.id})")'''

new_code = '''                for sp in sps.value:
                    if len(identities) < 10:
                        print(f"    ✓ {sp.display_name} ({sp.id})")
                    
                    # DEBUG: Log first Microsoft app we encounter
                    if len(identities) == 0 and 'Microsoft' in sp.display_name:
                        print(f"\\n  DEBUG: First Microsoft app fields:")
                        print(f"    - display_name: {sp.display_name}")
                        print(f"    - service_principal_type: {getattr(sp, 'service_principal_type', 'NOT FOUND')}")
                        print(f"    - app_owner_organization_id: {getattr(sp, 'app_owner_organization_id', 'NOT FOUND')}")
                        print(f"    - publisher_name: {getattr(sp, 'publisher_name', 'NOT FOUND')}")
                        print(f"    - app_id: {sp.app_id}")'''

if old_code in content:
    content = content.replace(old_code, new_code)
    print("✅ Added debug logging")
else:
    print("⚠️  Could not add debug logging")

with open('azure_discovery.py', 'w') as f:
    f.write(content)

print("Debug logging added - run discovery to see what fields exist")
