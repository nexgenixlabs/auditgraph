{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/static/*", "/favicon.ico", "/manifest.json", "/*.png"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Content-Security-Policy": "frame-ancestors 'none'"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js": "application/javascript",
    ".css": "text/css"
  }
}
