# Docker Compose local development credentials
# Copy to .env.docker and replace with strong passwords before running docker-compose up.
#
#   cp .env.docker.example .env.docker
#   # Edit .env.docker with strong passwords
#   docker-compose up
#
POSTGRES_DEV_PASSWORD=change-me-before-use
POSTGRES_DEV_ADMIN_PASSWORD=change-me-before-use
